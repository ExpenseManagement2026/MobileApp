<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvCurrentBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/budget_current"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtBudget"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_budget"
            android:inputType="number"
            android:importantForAutofill="yes"
            android:autofillHints="postalAddress" />

        <Button
            android:id="@+id/btnSaveBudget"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:layout_gravity="center_horizontal"
            android:minWidth="180dp"
            android:text="@string/save_budget" />

        <TextView
            android:id="@+id/tvUsedPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/used_percent_default" />

        <ProgressBar
            android:id="@+id/progressBudget"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/remaining_default" />

        <TextView
            android:id="@+id/tvBudgetStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/status_default" />
    </LinearLayout>
</ScrollView>